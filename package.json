{
  "name": "geochat",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "map-module",
    "chat-module",
    "host-app"
  ],
  "scripts": {
    "dev": "concurrently -n map,chat,host -c cyan,magenta,green \"npm run dev -w map-module\" \"npm run dev -w chat-module\" \"npm run dev -w host-app\"",
    "build:map": "npm run build -w map-module",
    "build:chat": "npm run build -w chat-module",
    "build:host": "npm run build -w host-app",
    "build": "npm run build:map && npm run build:chat && npm run build:host",
    "db:generate": "npx dotenv-cli -e .env -- npx prisma generate",
    "db:push": "npx dotenv-cli -e .env -- npx prisma db push",
    "db:seed": "npx dotenv-cli -e .env -- tsx prisma/seed.ts",
    "db:studio": "npx dotenv-cli -e .env -- npx prisma studio"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0"
  }
}
