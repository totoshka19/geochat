{
  "name": "geochat",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx --env-file=.env server.ts\"",
    "dev:front": "vite",
    "dev:api": "tsx --env-file=.env server.ts",
    "build": "prisma generate && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:generate": "npx dotenv-cli -e .env -- npx prisma generate",
    "db:push": "npx dotenv-cli -e .env -- npx prisma db push",
    "db:seed": "npx dotenv-cli -e .env -- tsx prisma/seed.ts",
    "db:studio": "npx dotenv-cli -e .env -- npx prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@reduxjs/toolkit": "^2.9.0",
    "groq-sdk": "^1.1.2",
    "maplibre-gl": "^5.21.1",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^8.0.0",
    "react-redux": "^9.0.0",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supercluster": "^7.1.3",
    "@vercel/node": "^5.7.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "express": "^5.2.1",
    "globals": "^15.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0"
  }
}
